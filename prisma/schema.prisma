generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String     @id @default(cuid())
  name      String     @db.VarChar(255)
  username  String     @unique @db.VarChar(100)
  email     String     @unique @db.VarChar(255)
  password  String     @db.VarChar(255)
  isActive  Boolean    @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  posts     Post[]
  roles     UserRole[]
}

model Role {
  id          String     @id @default(cuid())
  name        String     @unique
  displayName String
  isSystem    Boolean    @default(false)
  users       UserRole[]
}

model UserRole {
  userId String
  roleId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Post {
  id          String    @id @default(cuid())
  title       String    @db.VarChar(255)
  slug        String    @unique @db.VarChar(255)
  content     String    @db.Text
  excerpt     String?   @db.Text
  image       String?   @db.Text
  status      String    @default("draft") @db.VarChar(20) // draft, published, archived
  featured    Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  authorId    String
  categoryId  String?
  author      User      @relation(fields: [authorId], references: [id])
  category    Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  tags        PostTag[]
}

model Category {
  id    String @id @default(cuid())
  name  String @db.VarChar(100)
  slug  String @unique @db.VarChar(100)
  color String @default("#DC2626") @db.VarChar(20)
  posts Post[]
}

model Tag {
  id    String    @id @default(cuid())
  name  String    @db.VarChar(100)
  slug  String    @unique @db.VarChar(100)
  posts PostTag[]
}

model PostTag {
  postId String
  tagId  String
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  tag    Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([postId, tagId])
}

model Page {
  id        String   @id @default(cuid())
  title     String   @db.VarChar(255)
  slug      String   @unique @db.VarChar(255)
  content   String   @db.Text
  layout    String   @default("default") @db.VarChar(20) // default, full-width
  status    String   @default("published") @db.VarChar(20) // draft, published
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  menuItems MenuItem[]
}

model Menu {
  id        String     @id @default(cuid())
  name      String     @db.VarChar(100)
  location  String     @unique @db.VarChar(20) // header, footer
  items     MenuItem[]
}

model MenuItem {
  id       String   @id @default(cuid())
  label    String   @db.VarChar(255)
  url      String?  @db.Text
  pageId   String?
  parentId String?
  menuId   String
  order    Int      @default(0)
  isActive Boolean  @default(true)
  page     Page?    @relation(fields: [pageId], references: [id], onDelete: SetNull)
  parent   MenuItem? @relation("MenuItemParent", fields: [parentId], references: [id], onDelete: SetNull)
  children MenuItem[] @relation("MenuItemParent")
  menu     Menu     @relation(fields: [menuId], references: [id], onDelete: Cascade)
}

model Album {
  id          String        @id @default(cuid())
  title       String        @db.VarChar(255)
  slug        String        @unique @db.VarChar(255)
  description String?       @db.Text
  coverImage  String?       @db.Text
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  items       GalleryItem[]
}

model GalleryItem {
  id          String   @id @default(cuid())
  title       String?  @db.VarChar(255)
  image       String   @db.Text
  description String?  @db.Text
  albumId     String
  album       Album    @relation(fields: [albumId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
}

model Testimonial {
  id            String  @id @default(cuid())
  name          String  @db.VarChar(255)
  photo         String? @db.Text
  content       String  @db.Text
  title         String? @db.VarChar(255) // e.g., "Anggota DXIC", "Pengurus"
  order         Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Partner {
  id          String   @id @default(cuid())
  name        String   @db.VarChar(255)
  logo        String   @db.Text
  description String?  @db.Text
  website     String?  @db.Text
  order       Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Contact {
  id        String   @id @default(cuid())
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(255)
  phone     String?  @db.VarChar(50)
  subject   String?  @db.VarChar(255)
  message   String   @db.Text
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Setting {
  id    String @id @default(cuid())
  key   String @unique @db.VarChar(100)
  value String @db.Text
}

model SiteProfile {
  id              String @id @default(cuid())
  clubName        String @db.VarChar(255)
  shortName       String @db.VarChar(50)
  slogan          String @db.VarChar(255)
  description     String? @db.Text
  address         String? @db.Text
  phone           String? @db.VarChar(50)
  email           String? @db.VarChar(255)
  logo            String? @db.Text
  favicon         String? @db.Text
  vision          String? @db.Text
  mission         String? @db.Text
  about           String? @db.Text
  history         String? @db.Text
  homeBanner      String? @db.Text
  primaryColor    String @default("#DC2626") @db.VarChar(20)
  instagramUrl    String? @db.Text
  youtubeUrl      String? @db.Text
  facebookUrl     String? @db.Text
  twitterUrl      String? @db.Text
  memberCount     Int?
  cityCount       Int?
  establishedYear String? @db.VarChar(10)
}
